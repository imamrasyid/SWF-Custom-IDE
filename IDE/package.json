{
  "author": "EyeTracker",
  "name": "wayangide",
  "version": "3.0.0",
  "description": "Wayang IDE - Custom SWF IDE",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npx tsx scripts/obfuscate.ts && electron-builder --win --publish never && npx tsx scripts/flip-fuses.ts",
    "build:clean": "npm run clean && tsc && vite build && electron-builder --win --publish never && npx tsx scripts/flip-fuses.ts",
    "build:dev": "npm run clean && tsc && vite build && electron-builder --win --publish never",
    "build:obfuscate": "tsc && vite build && npx tsx scripts/obfuscate.ts",
    "build:package": "electron-builder --win --publish never && npx tsx scripts/flip-fuses.ts",
    "clean": "node -e \"const fs=require('fs'); ['release','dist','dist-electron','app.asar.unpacked'].forEach(d=>{if(fs.existsSync(d))fs.rmSync(d,{recursive:true,force:true})})\"",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "obfuscate": "npx tsx scripts/obfuscate.ts",
    "flip-fuses": "npx tsx scripts/flip-fuses.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@stablelib/base64": "^2.0.1",
    "@types/crypto-js": "^4.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "crypto-js": "^4.2.0",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.400.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.0.0",
    "react-arborist": "^3.10.5",
    "react-dom": "^19.0.0",
    "simple-git": "^3.36.0",
    "tailwindcss": "^4.3.1",
    "tweetnacl": "^1.0.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "javascript-obfuscator": "^5.4.3",
    "node-addon-api": "^7.0.0",
    "node-gyp": "^10.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "allowScripts": {
    "electron@42.4.1": true,
    "node-addon-api@7.0.0": true,
    "esbuild@0.28.1": true,
    "electron-winstaller@5.4.0": true
  }
}
